{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "devCommand": "bun run dev",
  "github": {
    "silent": false
  },
  "functions": {
    "src/app/api/players/search/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/seed/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/players/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/auth/login/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/match/create/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/match/action/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/match/join/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/match/state/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/match/pause/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/match/resume/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/players/stats/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/players/ogol/route.ts": {
      "maxDuration": 30
    }
  }
}
